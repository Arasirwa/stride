# in-browser mock seeded from src/data/db.json, no backend required.
#
# Once a real backend exists, point this at it and the app will use it
# automatically for all product reads/writes (GET/POST/PUT/DELETE /products).
# VITE_API_BASE_URL=https://api.example.com
